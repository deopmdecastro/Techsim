# =========================
# Techsim local development
# Copie este ficheiro para .env
# =========================
#
# Duas formas de correr localmente:
# 1) Com Docker (docker-compose.dev.yml): nginx expõe tudo em :8080,
#    incluindo o frontend e /api -> mantém os valores abaixo como estão.
# 2) Sem Docker (npm run dev + npm run backend:dev, sem nginx):
#    o backend fica a ouvir diretamente em PORT (por omissão 4000).
#    Nesse caso muda VITE_API_URL / VITE_REALTIME_URL para apontar
#    para http://localhost:4000, ou define PORT=8080 no backend.
#    Se apontares para uma porta onde nada está a ouvir, o browser
#    mostra um erro de CORS enganador (na verdade é ERR_CONNECTION_REFUSED).

# ---------- Frontend ----------
VITE_API_URL=http://localhost:8080/api
VITE_REALTIME_URL=http://localhost:8080
VITE_AUTH_MODE=remote
VITE_PROJECT_MODE=remote
VITE_APP_NAME=Techsim Platform Industrial

# ---------- Backend ----------
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=techsim
POSTGRES_USER=techsim
POSTGRES_PASSWORD=techsim

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Uploads / logs ----------
UPLOAD_DIR=backend/uploads
LOG_LEVEL=info
