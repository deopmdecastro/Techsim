# =========================
# Techsim local development
# Copie este ficheiro para .env
# =========================

# ---------- Frontend ----------
VITE_API_URL=http://localhost:8080/api
VITE_REALTIME_URL=http://localhost:8080
VITE_AUTH_MODE=remote
VITE_PROJECT_MODE=remote
VITE_APP_NAME=Techsim Platform Industrial

# ---------- Backend ----------
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=techsim
POSTGRES_USER=techsim
POSTGRES_PASSWORD=techsim

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Uploads / logs ----------
UPLOAD_DIR=backend/uploads
LOG_LEVEL=info
